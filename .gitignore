# --- Environment (Docker Compose / local only) ---
# 실제 값은 `.env`에만 두고 커밋하지 않는다. 키 이름만은 `.env.example`에 둔다.
.env
.env.*
!.env.example
!.env.deploy.example
# 로컬 전용 env (문서상 hybrid / deploy 실값)
hybrid.env

# --- Terraform (state·로컬 변수; 예시 파일만 추적) ---
**/terraform.tfstate
**/terraform.tfstate.*
**/.terraform/
*.tfvars
*.tfvars.json
!**/*.tfvars.example
*.auto.tfvars
*.auto.tfvars.json

# --- Keys & credential files (never commit) ---
*.pem
*.p12
*.pfx
id_rsa
id_rsa.*
*.key
.aws/credentials

# --- Build outputs ---
target/
build/
out/
*.class

# --- Node.js / pnpm workspace / Next.js (모노레포 공통; lockfile은 커밋) ---
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
.vercel/
coverage/
.nyc_output/
*.tsbuildinfo

# --- Gradle ---
.gradle/
.gradle-agent-temp-cache/
# IDE/ stray outputs next to services (sources live under src/; prefer build/)
services/*/bin/
*.hprof

# --- IDE / OS ---
.idea/
*.iml
# Track shared VS Code/Cursor configs; ignore other local .vscode files.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/
.gitleaks-*.json

# --- Personal local docs (never commit) ---
private-docs/
