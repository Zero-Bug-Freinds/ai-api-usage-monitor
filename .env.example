# Copy to `.env` for local Docker Compose overrides (do not commit `.env`).
# CI는 이 파일을 로드하지 않는다(`docker compose config`는 체크아웃에 .env 없이 실행). 아래 로컬 전용 플레이스홀더는 gitleaks 예외 대상이다(.gitleaks.toml, docs/CI.md).
#
# --- Monorepo web (pnpm workspace) ---
# 루트 package.json + pnpm-workspace.yaml + pnpm-lock.yaml 로 packages/ui(@ai-usage/ui) 와 services/*/web 을 한 번에 설치한다.
#   pnpm install   (또는 전역 pnpm 없으면: npx pnpm@9 install)
# 로컬에서 Next를 호스트 실행할 때 예시 포트(팀 합의):
#   identity web:   http://localhost:3000
#   usage web:      http://localhost:3001
# 단일 도메인 통합 시에는 엣지 프록시가 위 앱들로 나눈다(docs/architecture.md §10.2).
#   docker compose --profile web: web-edge(기본 :8888) + docker/web-edge/nginx.conf —
#   /dashboard·/billing·/teams·/notifications·/agent 는 각 web으로 분기;
#   identity 소유 경로만 identity-web; /api/team/v1/* 는 team-web BFF; /api/v1/* 는 api-gateway-service; 그 외 → 404.
#
# proxy-service — local test keys (rotate if leaked; production uses API Key Service)
# Google 키만 쓸 때: PROXY_GOOGLE_TEST_API_KEY 만 채우고, 게이트웨이는 /api/v1/ai/google/... 경로 (docs/local-run-and-usage-verification.md §2.1)
# PROXY_OPENAI_TEST_API_KEY=sk-...
# PROXY_GOOGLE_TEST_API_KEY=AIza...
# Optional: single key for all providers when provider-specific lines are empty
# PROXY_MOCK_KEY_FALLBACK=
#
# Gateway ↔ Proxy ↔ usage-service 공유 비밀 (docs/contracts/gateway-proxy.md).
# 로컬 기본값은 세 서비스 application.yml 과 동일: local-dev-gateway-shared-secret-do-not-use-in-prod (운영에서는 강한 값으로 교체).
# Docker Compose 가 ${GATEWAY_SHARED_SECRET:-} 로 넘기므로 .env 에 빈 값(GATEWAY_SHARED_SECRET=)만 두면 컨테이너에서 기본값이 무력화될 수 있음 — 줄 삭제 또는 아래와 같이 비어 있지 않은 값 사용.
GATEWAY_SHARED_SECRET=local-dev-gateway-shared-secret-do-not-use-in-prod
#
# JWT 검증용 (GATEWAY_DEV_MODE=false 일 때 gateway.jwt.secret 과 동일한 HMAC 키)
GATEWAY_DEV_MODE=false
GATEWAY_JWT_SECRET=change-this-secret-key-to-at-least-32-bytes
# Gateway CORS 허용 Origin 목록(쉼표 구분). 기본 단일 진입점(web-edge): 8888
# 예) GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:8888,http://127.0.0.1:8888
# 보안: allowCredentials=true 이므로 wildcard(*) 사용 금지
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:8888

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# team-service 전용 PostgreSQL(Compose postgres-team; identity postgres 와 분리)
TEAM_POSTGRES_HOST=localhost
TEAM_POSTGRES_PORT=5434
TEAM_POSTGRES_DB=team_db
TEAM_POSTGRES_USER=team_app
TEAM_POSTGRES_PASSWORD=team_app
# postgres-team 초기 SQL 은 team_app/team_db 고정. init 실패·역할 없음 시: docker volume rm …postgres_team_data 후 postgres-team 재기동

# usage-service 전용 DB (identity-service 는 POSTGRES_DB=app 만 사용)
# Compose postgres 컨테이너 첫 기동(빈 볼륨) 시 02-create-usage-db.sh 로 생성됨
USAGE_POSTGRES_DB=usage_db
USAGE_POSTGRES_USER=usage_app
USAGE_POSTGRES_PASSWORD=usage_app
USAGE_POSTGRES_HOST=localhost
USAGE_POSTGRES_PORT=5433

# billing-service 전용 DB (Compose postgres-billing; 첫 기동 시 03-create-billing-db.sh)
BILLING_POSTGRES_DB=billing_db
BILLING_POSTGRES_USER=billing_app
BILLING_POSTGRES_PASSWORD=billing_app
BILLING_POSTGRES_HOST=localhost
BILLING_POSTGRES_PORT=5435

# notification-service 전용 DB (Compose postgres-notification; 첫 기동 시 04-create-notification-db.sh)
NOTIFICATION_POSTGRES_DB=notification_db
NOTIFICATION_POSTGRES_USER=notification_app
NOTIFICATION_POSTGRES_PASSWORD=notification_app
NOTIFICATION_POSTGRES_HOST=localhost
NOTIFICATION_POSTGRES_PORT=5436

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
REDIS_PORT=6379

# usage-service (호스트 실행 시 기본 8092; DB 는 USAGE_POSTGRES_* 로 app 과 분리)
# USAGE_SERVICE_PORT=8092
# billing → usage 비용 확정 스트림 (기본값은 application.yml 과 동일, docs/billing-service-overview-20260412.md)
# USAGE_RABBIT_COST_FINALIZED_ENABLED=true
# USAGE_RABBIT_COST_FINALIZED_EXCHANGE=billing.events
# USAGE_RABBIT_COST_FINALIZED_ROUTING_KEY=usage.cost.finalized
# USAGE_RABBIT_COST_FINALIZED_QUEUE=usage-service.usage-cost-finalized.queue

# team-service(기본 8093) / billing-service(기본 8095) — bootrun 스크립트는 team 8094·billing 8095 로 맞춤
# TEAM_SERVICE_PORT — 호스트에서 Gradle/IDE bootRun 할 때만 Spring server.port 로 쓰임 (Compose team-service 컨테이너 내부 포트와 별개).
TEAM_SERVICE_PORT=8094
# TEAM_SERVICE_HOST_PORT — 루트 docker-compose.yml 의 team-service `ports:` 호스트 바인딩만 (기본 8093). TEAM_SERVICE_PORT(8094)와 이름을 나눠 Docker Desktop 이 호스트 8094를 선점하는 유형 B 충돌을 피한다.
TEAM_SERVICE_HOST_PORT=8093
BILLING_SERVICE_PORT=8095
# Gateway → billing-service HTTP (Compose 네트워크 기본)
GATEWAY_BILLING_URI=http://billing-service:8095
# Gateway → notification-service HTTP
# - Docker Compose(권장): http://notification-service:8096
# - 호스트에서 notification-service 단독 실행 시: http://host.docker.internal:8096
GATEWAY_NOTIFICATION_URI=http://notification-service:8096

# notification-service (Nest) — HTTP는 서비스 로컬 `.env` 의 `PORT`(기본 8096, billing 8095와 구분). DB 는 NOTIFICATION_POSTGRES_* / `services/notification-service/.env.example` 의 DATABASE_URL 과 맞출 것.
# Docker Compose: notification-service 호스트 포트(좌측). 컨테이너 내부 포트는 8096 고정.
# 로컬에서 8096이 다른 프로세스에 의해 점유되는 경우가 흔해 기본값을 18096으로 둔다.
NOTIFICATION_SERVICE_PORT=18096
# Compose `notification-service` → RabbitMQ 팀 도메인 큐 소비 (team-service 기본 exchange/routing 과 맞춤: team.events / team-member-added)
# 끄려면: TEAM_EVENTS_CONSUMER_ENABLED=false
TEAM_EVENTS_CONSUMER_ENABLED=true
TEAM_EVENTS_QUEUE_NAME=notification.team.events
TEAM_EVENTS_ASSERT_TOPOLOGY=true
TEAM_EVENTS_EXCHANGE_NAME=team.events
TEAM_EVENTS_BINDING_KEYS=team-member-added
# notification-service 내부 시크릿(선택) — 비워두면 test-send는 self-only (내 사용자에게만)
NOTIFICATION_INTERNAL_SECRET=
# notification-service -> team-service internal API base (Docker Compose)
TEAM_SERVICE_INTERNAL_BASE_URL=http://team-service:8093

# billing → identity 월 예산(선택, docs/billing-identity-budget.md)
BILLING_IDENTITY_ENABLED=true
BILLING_IDENTITY_BASE_URL=http://identity-service:8080
BILLING_IDENTITY_BUDGET_PATH=/api/identity/v1/users/budget?email={userId}

# billing pricing seed (local/dev)
# When true, inserts missing rows from OfficialProviderModelPriceCatalog even if the table is not empty.
BILLING_PRICING_SEED_MISSING=true

# scripts/verify-expenditure-chain.ps1|sh — GATEWAY_DEV_MODE=false 일 때 2단계(게이트웨이 JWT 경로) 검사용 (선택)
# 게이트웨이는 identity 가 발급한 JWT 를 검증하므로 GATEWAY_JWT_SECRET 과 identity 의 JWT_SECRET(서명 키)이 같아야 한다.
# EXPENDITURE_VERIFY_GATEWAY_JWT=eyJhbGciOiJIUzI1NiJ9...
# EXPENDITURE_VERIFY_LOGIN_EMAIL=you@example.com
# EXPENDITURE_VERIFY_LOGIN_PASSWORD=your-local-password
# EXPENDITURE_VERIFY_IDENTITY_URL=http://127.0.0.1:8090

# Docker Compose — Next.js web 이미지(profile: web, docs/architecture.md §10.1)
# identity-web: services/identity-service/web — usage-web: services/usage-service/web — billing-web: services/billing-service/web
# 브라우저 공개 경로는 web-edge(:8888)를 통과한다.
# IDENTITY_WEB_PORT=3000
# USAGE_WEB_PORT=3001
# BILLING_WEB_PORT=3003
# billing-web 서버 라우트가 컨테이너 안에서 web-edge의 /api/team/v1/** 라우트를 호출할 때 사용할 오리진.
# Compose 기본은 동일 네트워크의 web-edge(http://web-edge). 호스트 전용 구성에서만 덮어쓴다.
# BILLING_TEAM_BFF_BASE_URL=http://localhost:8888
# team-web(BFF) 호스트 포트. 루트 docker-compose 기본 3022. Main Shell(web-host) 기본 호스트 포트는 WEB_HOST_PORT=3002.
# TEAM_WEB_PORT=3022
NOTIFICATION_WEB_PORT=3004
# 단일 도메인 엣지(Nginx, profile web) — 브라우저 진입점
# WEB_EDGE_PORT=8888
# web-edge만 쓸 때 이미지 빌드용(둘 다 엣지 오리진으로 맞춤). 비우면 분리 포트(3000/3001) 기본.
# web-edge 단일 진입점 사용 시 두 값 모두 8888로 고정 권장
NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=http://localhost:8888
NEXT_PUBLIC_USAGE_WEB_ORIGIN=http://localhost:8888
#
# --- apps/web (web-host, `apps/web`, basePath /teams) + `@ai-usage/shell` 공용 NEXT_PUBLIC_* ---
# Module Federation: 리모트 공개 origin(트레일링 슬래시 없음). `apps/web/next.config.mjs` 기본은 web-edge `…/mfe/team`·`…/mfe/usage`.
# NEXT_PUBLIC_MFE_TEAM_REMOTE_URL=http://localhost:8888/mfe/team
# NEXT_PUBLIC_MFE_USAGE_REMOTE_URL=http://localhost:8888/mfe/usage
# MFE를 엣지 없이 단독 dev 포트로 띄울 때 예(docker-compose.yml 의 TEAM_WEB_MFE_PORT / USAGE_WEB_MFE_PORT 와 호스트 포트 일치).
# team-web-mfe는 assetPrefix 기본 `/mfe/team` 이므로 remote 베이스에 경로까지 포함해야 함.
NEXT_PUBLIC_MFE_TEAM_REMOTE_URL=http://localhost:3012/mfe/team
# NEXT_PUBLIC_MFE_USAGE_REMOTE_URL=http://localhost:3013
# 셸 팀 콘솔(Main Shell, web-edge). 타 앱에서도 안전하려면 절대 URL 권장(Task37-13).
# NEXT_PUBLIC_TEAM_SHELL_HREF=http://localhost:8888/teams
# NEXT_PUBLIC_WEB_EDGE_ORIGIN=http://localhost:8888
# NEXT_PUBLIC_USAGE_BASE_PATH=/dashboard
#
# --- usage-service `web-mfe` (MF remote) ---
# 브라우저에서 usage BFF를 호출할 때 베이스(트레일링 슬래시 없음). 비우면 임베드 페이지에서 `window.location.origin` 사용.
# web-host를 `http://localhost:3100` 등으로 띄우고 `/teams`에 임베드할 때 예:
# NEXT_PUBLIC_USAGE_BFF_BASE_URL=http://localhost:3100/teams
#
# --- team-service `web-mfe` (MF remote; usage 리모트 동적 로드 빌드 시) ---
# 기본 `http://localhost:3011`(`services/team-service/web-mfe/.env.example`). web-edge 단일 진입이면 위 MFE usage 줄과 동일 오리진 권장.
# NEXT_PUBLIC_MFE_USAGE_REMOTE_URL=http://localhost:3011
#
# team-service `web/`(Next BFF, team-web) 서버 전용: `services/team-service/web/.env.example` 의 GATEWAY_URL·IDENTITY_SERVICE_URL.
# usage-service `web/`(Next BFF, usage-web) 서버 전용: `services/usage-service/web/.env.example` 의 API_GATEWAY_URL·IDENTITY_SERVICE_URL 등.
# packages/ui — 런타임 env 없음.
#
# 컨테이너 → 호스트에서 실행 중인 identity-service (기본 8090; 게이트웨이가 8080 이면 포트 분리)
# WEB_IDENTITY_SERVICE_URL=http://host.docker.internal:8090
# 컨테이너 team-web → team-service BFF. profile web 에서 Compose 가 team-service 를 띄우면 이 줄을 비우면 docker-compose 기본 http://team-service:8093. 호스트에서만 team 을 bootRun(8094) 할 때만 설정한다.
# WEB_TEAM_SERVICE_URL=http://host.docker.internal:8094
# 컨테이너 team-web → API Gateway(base URL). 기본값은 Compose 네트워크의 http://api-gateway-service:8080.
# 호스트에서 게이트웨이를 따로 띄우는 경우에만 아래 값을 설정한다.
# WEB_GATEWAY_URL=http://host.docker.internal:8080
# 컨테이너 notification-web → notification-service. 기본값은 Compose 네트워크의 http://notification-service:8096.
# 호스트에서 notification-service 를 따로 띄우는 경우에만 아래 값을 설정한다.
# WEB_NOTIFICATION_SERVICE_URL=http://host.docker.internal:8096/api
# notification-web BFF 업스트림: `direct`(기본) 또는 `gateway` (Gateway `/api/notification/**` 경유 시).
# NOTIFICATION_HTTP_UPSTREAM=direct
# gateway 모드일 때 BFF가 사용할 API Gateway 베이스 URL(트레일링 슬래시 없음).
# API_GATEWAY_URL=http://localhost:8080
# notification-web 폴링 간격(ms). 기본 10000. (너무 낮추면 로컬에서도 불필요한 트래픽이 늘어남)
# NEXT_PUBLIC_NOTIFICATION_POLL_MS=10000
# team-service 팀 API Key 암호화 시크릿(운영에서는 충분히 긴 값으로 교체)
# TEAM_API_KEY_ENCRYPTION_SECRET=change-this-team-api-key-encryption-secret-min-32-chars

# Docker Compose — 호스트 포트 매핑 (선택)
# PROXY_SERVICE_PORT=8081
# API_GATEWAY_PORT=8080
# 호스트에서 identity 가 8080 을 쓰면 게이트웨이와 충돌하므로 API_GATEWAY_PORT=8088 등으로 분리
#
# identity-service 는 Compose 가 아닌 호스트에서 실행. 컨테이너 proxy → 호스트 키 서비스:
# PROXY_KEY_SERVICE_BASE_URL=http://host.docker.internal:8080
# (identity 가 8090 이면 :8090 으로; application.yml 의 key-service 포트와 일치)
# 팀 요청 전용 키 조회(team-service 내부 API)용 업스트림 (Task46)
# PROXY_TEAM_KEY_SERVICE_BASE_URL=http://host.docker.internal:8093
# PROXY_TEAM_KEY_SERVICE_INTERNAL_TOKEN=
# PROXY_TEAM_KEY_SERVICE_PATH_TEMPLATE=/internal/api-keys/{provider}
# Gateway → usage-service HTTP (Compose 네트워크 기본)
GATEWAY_USAGE_URI=http://usage-service:8092
# usage-service dashboard API (optional)
# USAGE_GATEWAY_SHARED_SECRET=
# USAGE_ANALYTICS_MAX_RANGE_DAYS=400

# --- Identity Service SMTP 설정 (Gmail 기준) ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=identity@zerobugfreinds.com
SPRING_MAIL_PASSWORD=000000000

# SMTP 보안(TLS) 활성화 (필수)
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# 발신자 이메일 주소 (보통 USERNAME과 동일하게 맞춤)
IDENTITY_PASSWORD_RESET_MAIL_FROM=identity@zerobugfreinds.com

# (참고) 실제 사용자가 클릭할 도메인 주소 (로컬 테스트 시)
IDENTITY_WEB_PUBLIC_BASE_URL=http://localhost:8888

# Agent web (web-edge routes /agent)
# AGENT_WEB_PORT=3005
# (호환) 기존 변수명도 읽을 수 있음: AI_AGENT_WEB_PORT
# agent-web BFF -> agent-service/team-service 내부 오리진 (하이브리드 실행 시 권장)
# AI_AGENT_SERVICE_INTERNAL_ORIGIN=http://host.docker.internal:8096
# TEAM_SERVICE_INTERNAL_ORIGIN=http://host.docker.internal:8094
# agent-service Gemini 키(없으면 PROXY_GOOGLE_TEST_API_KEY/GOOGLE_API_KEY fallback 시도)
AI_AGENT_GEMINI_API_KEY=your-gemini-api-key
AI_AGENT_GEMINI_MODEL=gemini-2.5-flash
# 팀 API 키 컨텍스트 조회에 사용할 사용자 식별자(이메일 또는 ID). 예: happy@test.com
# AI_AGENT_TEAM_CATALOG_USER_ID=

AI_AGENT_RECOMMENDATION_CATALOG_URL=https://openrouter.ai/api/v1/models
AI_AGENT_RECOMMENDATION_CATALOG_API_KEY=...
AI_AGENT_RECOMMENDATION_CATALOG_OPENROUTER_REFERER=http://localhost:8888
AI_AGENT_RECOMMENDATION_CATALOG_OPENROUTER_TITLE=ai-api-usage-monitor
