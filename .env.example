# Copy to `.env` for local Docker Compose overrides (do not commit `.env`).
#
# proxy-gateway-service (local OpenAI test key — rotate if leaked; production uses API Key Service)
# PROXY_OPENAI_TEST_API_KEY=sk-...

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
REDIS_PORT=6379
