# Copy to `.env.deploy` on the deploy host (do not commit real secrets).
# Placeholder values are documented deploy-shape examples; gitleaks allowlist: .gitleaks.toml.
# Used by: `docker compose -f docker-compose.prod.yml --env-file .env.deploy`
# CI: `docker compose ... --env-file .env.deploy.example config` (placeholders only).

ECR_IMAGE_PREFIX=000000000000.dkr.ecr.us-east-1.amazonaws.com/ai-api-usage-monitor
IMAGE_TAG=example-tag

IDENTITY_POSTGRES_HOST=identity-db.example.rds.amazonaws.com
IDENTITY_POSTGRES_PORT=5432
IDENTITY_POSTGRES_DB=identity
IDENTITY_POSTGRES_USER=identity_app
IDENTITY_POSTGRES_PASSWORD=change-me-identity-db

USAGE_POSTGRES_HOST=usage-db.example.rds.amazonaws.com
USAGE_POSTGRES_PORT=5432
USAGE_POSTGRES_DB=usage
USAGE_POSTGRES_USER=usage_app
USAGE_POSTGRES_PASSWORD=change-me-usage-db

BILLING_POSTGRES_HOST=billing-db.example.rds.amazonaws.com
BILLING_POSTGRES_PORT=5432
BILLING_POSTGRES_DB=billing
BILLING_POSTGRES_USER=billing_app
BILLING_POSTGRES_PASSWORD=change-me-billing-db

TEAM_POSTGRES_HOST=team-db.example.rds.amazonaws.com
TEAM_POSTGRES_PORT=5432
TEAM_POSTGRES_DB=team
TEAM_POSTGRES_USER=team_app
TEAM_POSTGRES_PASSWORD=change-me-team-db

RABBITMQ_HOST=b-1.example.amazonaws.com
RABBITMQ_PORT=5671
RABBITMQ_USER=app
RABBITMQ_PASSWORD=change-me-rabbitmq
RABBITMQ_SSL_ENABLED=true

JWT_SECRET=change-me-jwt-at-least-32-chars-long
GATEWAY_SHARED_SECRET=change-me-gateway-shared-secret
GATEWAY_JWT_SECRET=change-me-gateway-jwt-secret

TEAM_API_KEY_ENCRYPTION_SECRET=change-me-team-api-key-encryption-32b

NOTIFICATION_DATABASE_URL=postgresql://notification_app:change-me@notification-db.example.rds.amazonaws.com:5432/notification
NOTIFICATION_RABBITMQ_URL=amqps://notification:change-me@b-1.example.amazonaws.com:5671/%2f
NOTIFICATION_INTERNAL_SECRET=change-me-notification-internal

NEXT_PUBLIC_WEB_EDGE_ORIGIN=https://app.example.com
NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=https://app.example.com
