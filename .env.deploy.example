# Copy to `.env.deploy` on the deploy host (do not commit real secrets).
# Placeholder values are documented deploy-shape examples; gitleaks allowlist: .gitleaks.toml.
# CI: `docker compose -f docker-compose-prod.yml --env-file .env.deploy.example config`
#
# On EC2, `scripts/deploy/on-instance-compose-roll.sh` (SSM / Release) reads this file,
# merges IMAGE_TAG + ECR_IMAGE_PREFIX, writes:
#   /var/lib/ai-api-usage-monitor-deploy/compose.env
#   ${DEPLOY_ROOT}/.env
# then runs `docker compose --env-file` + `--force-recreate`.
# Do not run bare `sudo docker compose -f docker-compose-prod.yml` (no env) — use:
#   ./scripts/deploy/docker-compose-prod.sh logs -f
#
# Staging (single RDS): set every *_POSTGRES_HOST to the same hostname from
#   terraform output -raw staging_rds_address
# (hostname only — no quotes, no :5432 on *_POSTGRES_HOST; port is *_POSTGRES_PORT=5432).
# Hostname only — run: terraform output -raw staging_rds_address (suffix varies per account, e.g. ...chsis44o217i...)
# Run `scripts/deploy/rds-staging-create-logical-dbs.sh` once. RDS is private (VPC + SG from EC2 only).
# Pre-flight: ./scripts/deploy/validate-env-deploy.sh .env.deploy

ECR_IMAGE_PREFIX=000000000000.dkr.ecr.us-east-1.amazonaws.com/ai-api-usage-monitor
IMAGE_TAG=example-tag

# Host port published for web-edge (must match ALB target port / TARGET_PORT, default 8888).
WEB_EDGE_HOST_PORT=8888

# On EC2: /opt/ai-api-usage-monitor/.env.deploy — mode 600, owner root (SSM runs as root).
# IMAGE_TAG is overridden at deploy from GitHub Actions (DEPLOY_SHA).
IDENTITY_POSTGRES_HOST=ai-api-usage-monitor-stg-pg.cjce8ucqeom4.ap-northeast-2.rds.amazonaws.com
IDENTITY_POSTGRES_PORT=5432
IDENTITY_POSTGRES_DB=identity
IDENTITY_POSTGRES_USER=appadmin
IDENTITY_POSTGRES_PASSWORD=change-me-from-terraform-output

USAGE_POSTGRES_HOST=ai-api-usage-monitor-stg-pg.cjce8ucqeom4.ap-northeast-2.rds.amazonaws.com
USAGE_POSTGRES_PORT=5432
USAGE_POSTGRES_DB=usage
USAGE_POSTGRES_USER=appadmin
USAGE_POSTGRES_PASSWORD=change-me-from-terraform-output

BILLING_POSTGRES_HOST=ai-api-usage-monitor-stg-pg.cjce8ucqeom4.ap-northeast-2.rds.amazonaws.com
BILLING_POSTGRES_PORT=5432
BILLING_POSTGRES_DB=billing
BILLING_POSTGRES_USER=appadmin
BILLING_POSTGRES_PASSWORD=change-me-from-terraform-output

TEAM_POSTGRES_HOST=ai-api-usage-monitor-stg-pg.cjce8ucqeom4.ap-northeast-2.rds.amazonaws.com
TEAM_POSTGRES_PORT=5432
TEAM_POSTGRES_DB=team
TEAM_POSTGRES_USER=appadmin
TEAM_POSTGRES_PASSWORD=change-me-from-terraform-output

AGENT_POSTGRES_HOST=ai-api-usage-monitor-stg-pg.cjce8ucqeom4.ap-northeast-2.rds.amazonaws.com
AGENT_POSTGRES_PORT=5432
AGENT_POSTGRES_DB=agent
AGENT_POSTGRES_USER=appadmin
AGENT_POSTGRES_PASSWORD=change-me-from-terraform-output

# RabbitMQ on EC2 (enable_ec2_rabbitmq): merged from terraform-rabbitmq.env on deploy roll, or copy from:
#   terraform output -json ec2_rabbitmq_deploy_env
RABBITMQ_HOST=host.docker.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=app
RABBITMQ_PASSWORD=change-me-from-terraform-output-ec2_rabbitmq_password
RABBITMQ_SSL_ENABLED=false

JWT_SECRET=change-me-jwt-at-least-32-chars-long
GATEWAY_SHARED_SECRET=change-me-gateway-shared-secret
GATEWAY_JWT_SECRET=change-me-gateway-jwt-secret

TEAM_API_KEY_ENCRYPTION_SECRET=change-me-team-api-key-encryption-32b

# NOTIFICATION_DATABASE_URL host must match *_POSTGRES_HOST (same staging_rds_address).
NOTIFICATION_DATABASE_URL=postgresql://appadmin:change-me-from-terraform-output@REPLACE_WITH_staging_rds_address:5432/notification
# EC2 host broker (install-ec2-rabbitmq.sh): use host.docker.internal, not compose service name "rabbitmq".
NOTIFICATION_RABBITMQ_URL=amqp://app:change-me-from-terraform-output-ec2_rabbitmq_password@host.docker.internal:5672/%2f
NOTIFICATION_INTERNAL_SECRET=change-me-notification-internal

# Client bundle (sidebar 팀 링크 등): baked at **GitHub Release build**, not at EC2 compose roll.
# Set the same values as GitHub Environment variables (staging/production) — see docs/aws-github-oidc-ecr-ssm.md §10.
# EC2 `.env.deploy` alone does not rewrite already-built identity-web / usage-web images.
NEXT_PUBLIC_WEB_EDGE_ORIGIN=https://app.example.com
NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=https://app.example.com
# Optional; default with WEB_EDGE_ORIGIN set at identity-web build is https://app.example.com/teams
# NEXT_PUBLIC_TEAM_SHELL_HREF=/teams
# team-web Module Federation usage remote (build-arg on Release); e.g. https://app.example.com/mfe/usage
# NEXT_PUBLIC_MFE_USAGE_REMOTE_URL=https://app.example.com/mfe/usage
