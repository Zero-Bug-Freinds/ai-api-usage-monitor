aws_region             = "ap-northeast-2"
project_name           = "ai-api-usage-monitor"
github_org             = "Zero-Bug-Freinds"
github_repo            = "ai-api-usage-monitor"
ecr_repository_prefix  = "ai-api-usage-monitor"

# Default suffixes match .github/workflows/release.yml (see variable ecr_repository_suffixes in variables.tf).
# Override only if you use fewer images or different names:
# ecr_repository_suffixes = ["api-gateway-service", "proxy-service"]

# Optional IAM role names (defaults ReleaseRole, DeployRole).
# release_iam_role_name = "ReleaseRole"
# deploy_iam_role_name  = "DeployRole"

# ECR: untagged image retention (days); see aws_ecr_lifecycle_policy in modules/ecr.
# ecr_untagged_image_expire_days = 14

# Optional compute (VPC + ALB + ASG).
enable_compute_stack       = true
compute_environment_label  = "staging"
# alb_target_port          = 8888
# ALB health: default "traffic-port" probes the same port as alb_target_port (/healthz on web-edge :80 in-container). Use "8080" for the dedicated web-edge health listener only.
# alb_health_check_port    = "traffic-port"

# EC2 first boot: shallow clone repo into /opt/<project_name> when deploy scripts are missing (HTTPS; disable for private repos without token).
# ec2_bootstrap_git_clone_enabled = true
# ec2_bootstrap_git_clone_url     = "" # non-empty overrides https://github.com/<github_org>/<github_repo>.git

# ASG sizing: keep all three at 1 for a single EC2 (see compute_stack ASG availability_zone_distribution).
# Raise max/desired for HA only if you accept multiple instances behind the ALB.
# compute_asg_min_size         = 1
# compute_asg_max_size         = 1
# compute_asg_desired_capacity = 1

# Optional: one staging PostgreSQL RDS in the compute VPC (requires enable_compute_stack = true).
# enable_staging_rds = true
