# Usage `web/` — BFF → API Gateway (`/api/usage/**` → `{API_GATEWAY_URL}/api/v1/usage/**`). 계약: docs/contracts/web-gateway-bff.md
API_GATEWAY_URL=http://localhost:8080

# `gateway.dev-mode=true`와 맞출 때: BFF가 Identity 세션으로 `X-User-Id` 보강.
GATEWAY_DEV_MODE=true

# 위가 켜져 있을 때 필수 — Identity `GET /api/auth/session` 호출에 사용.
IDENTITY_SERVICE_URL=http://localhost:8090

# Identity `web/`가 다른 오리진일 때 로그인·로그아웃·미들웨어 리다이렉트. 단일 도메인 엣지에서는 엣지 URL(예: http://localhost:8888).
# NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=http://localhost:3000
#
# next.config basePath 와 동일(단일 도메인에서 /dashboard 로 묶을 때).
# NEXT_PUBLIC_BASE_PATH=/dashboard
