# --- Usage `web/` only (BFF → API Gateway → usage-service) ---
# 계약: docs/contracts/web-gateway-bff.md · 경계: docs/contracts/web-split-boundary.md
#
# Server-side only — 브라우저에 노출되지 않음.
# 게이트웨이 공개 베이스 URL(트레일링 슬래시 없음). BFF는 {API_GATEWAY_URL}/api/v1/usage/... 로 프록시한다.
API_GATEWAY_URL=http://localhost:8080

# `gateway.dev-mode=true`와 맞출 때: BFF가 Identity 세션으로 X-User-Id 보강.
GATEWAY_DEV_MODE=true

# GATEWAY_DEV_MODE 가 true/1 일 때 필수 — Identity `GET /api/auth/session` 호출에 사용.
IDENTITY_SERVICE_URL=http://localhost:8090

# --- Client (NEXT_PUBLIC_*) — 번들에 인라인됨; Docker 빌드 시 compose build.args 로도 주입 가능 ---
# Identity `web/`가 다른 오리진일 때 로그인·로그아웃·미들웨어 리다이렉트.
# 직접 `http://localhost:3001` 만 켜 두고 엣지 없이 개발하면 web-edge 공개 오리진으로 설정.
# 단일 도메인 엣지에서는 엣지 오리진(예: http://localhost:8888) 또는 비움(요청 호스트와 동일 오리진 가정).
# NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=http://localhost:8888

# `next.config.ts` 의 basePath 와 동기화(기본 /dashboard). 로컬에서만 바꿀 때는 next.config 와 함께 수정.
# NEXT_PUBLIC_BASE_PATH=/dashboard

# --- 로컬 dev (선택) ---
# PORT=3001

# --- usage `web-mfe/` (Module Federation) ---
# 브라우저에서 사용량 BFF를 호출할 때 베이스(트레일링 슬래시 없음). 비우면 임베드 페이지 `window.location.origin` 사용.
# 상세: `services/usage-service/web-mfe/.env.example`
