# Spring team-service (BFF → 이 주소로 프록시). 포트는 로컬 기동 방식에 맞출 것.
# - application.properties 기본: 8093
# - 루트 .env 에 TEAM_SERVICE_PORT=8094 로 두고 bootRun 하면: 8094
# - Docker Compose team-service 호스트 포트는 TEAM_SERVICE_HOST_PORT(기본 8093)
TEAM_SERVICE_URL=http://127.0.0.1:8094
# Compose/일부 스크립트에서만 쓰는 이름 — 있으면 TEAM_SERVICE_URL 대신 사용 가능
# WEB_TEAM_SERVICE_URL=http://127.0.0.1:8093
IDENTITY_SERVICE_URL=http://127.0.0.1:8090
