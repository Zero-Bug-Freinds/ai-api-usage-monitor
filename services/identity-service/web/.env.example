# --- Identity `web/` only (BFF → Spring identity-service) ---
# 계약·경로: docs/contracts/web-identity-bff.md, docs/contracts/web-split-boundary.md
#
# Server-side only — 브라우저에 노출되지 않음.
# Spring identity-service 베이스 URL(트레일링 슬래시 없음). 게이트웨이 8080과 겹치면 8090 등으로 띄운다.
IDENTITY_SERVICE_URL=http://localhost:8090

# --- Client (NEXT_PUBLIC_*) — 번들에 인라인됨 ---
# Usage `web/`가 다른 오리진(예: 로컬 :3001)일 때 랜딩·로그인 후 대시보드 절대 URL.
# 단일 도메인 엣지(동일 호스트·포트)에서는 비워도 된다.
# NEXT_PUBLIC_USAGE_WEB_ORIGIN=http://host.docker.internal:3001
# USAGE_WEB_INTERNAL_ORIGIN=http://host.docker.internal:3001
# Team BFF(team-web). 루트 Compose 기본 호스트 포트는 3022(TEAM_WEB_PORT). 컨테이너끼리면 team-web:3000.
# TEAM_WEB_INTERNAL_ORIGIN=http://host.docker.internal:3022

# --- 로컬 dev (선택) ---
# PORT=3000
