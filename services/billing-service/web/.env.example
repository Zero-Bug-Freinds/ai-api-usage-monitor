# 브라우저 → Next BFF → API Gateway → billing-service
API_GATEWAY_URL=http://localhost:8080

# 게이트웨이 개발 모드(로컬): Identity 세션으로 X-User-Id 보강 — usage-web BFF 와 동일
# GATEWAY_DEV_MODE=true
# IDENTITY_SERVICE_URL=http://localhost:8090

# 사용량 대시보드 — 사이드바 "사용량으로" (절대 URL로 열어 `/billing/dashboard` 404 방지)
# NEXT_PUBLIC_USAGE_WEB_ORIGIN=http://localhost:3001
# NEXT_PUBLIC_USAGE_BASE_PATH=/dashboard
# Identity 셸과 같은 브라우저 오리진(기본 dev: next.config 에서 localhost:3000)
# NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=http://localhost:3000
