# 브라우저 → Next BFF → API Gateway → billing-service
API_GATEWAY_URL=http://localhost:8080

# 게이트웨이 개발 모드(로컬): Identity 세션으로 X-User-Id 보강 — usage-web BFF 와 동일
# GATEWAY_DEV_MODE=true
# IDENTITY_SERVICE_URL=http://localhost:8090

# Identity 와 분리 포트로만 띄울 때 로그아웃·절대 링크용(기본 dev: next.config 에서 localhost:3000)
# NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=http://localhost:3000

# 서버 라우트가 팀 멤버 조회(GET /api/team/v1/teams/{id}/members)를 할 때 사용할 오리진(identity-web BFF).
# 로컬 단독 실행 시 보통 identity-web 과 동일 포트(예: http://localhost:3000). Docker Compose 는 루트 .env.example 의 BILLING_TEAM_BFF_BASE_URL 참고.
# BILLING_TEAM_BFF_BASE_URL=http://localhost:3000
