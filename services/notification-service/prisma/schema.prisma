// Notification Service — 로컬/배포 DB URL은 환경변수 (docs/architecture.md §12)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 아웃바운드 알림 발송 시도·멱등 키 추적 (최소 스키마 — 팀이 확장)
model NotificationDelivery {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 동일 스코프·기간·임계치 등 팀 합의 문자열 (중복 발송 방지)
  dedupeKey String   @unique @map("dedupe_key")
  channel   String
  status    String
  payload   Json?

  @@map("notification_deliveries")
}

/// 인앱 알림 (수신자별 목록·읽음 상태; 진실 공급원은 notification DB)
model InAppNotification {
  id        String    @id @default(uuid()) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 수신자 — Identity 등에서 쓰는 내부 사용자 ID(문자열)
  userId    String    @map("user_id")
  title     String
  body      String    @db.Text
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  /// 선택적 분류(예: billing-warning, test)
  type      String?
  /// UI 렌더링/액션 처리에 필요한 추가 데이터 (예: invitationId, action paths)
  meta      Json?

  @@index([userId, createdAt(sort: Desc)])
  @@map("in_app_notifications")
}
