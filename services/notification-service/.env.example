# PostgreSQL — 로컬에서 DB 생성 후 연결 (루트 docker-compose.yml 의 postgres 등)
# 예: createdb notification_db && psql -c "CREATE USER notification_app WITH PASSWORD 'notification_app';" ...
DATABASE_URL="postgresql://app:app@localhost:5432/notification_db"

# HTTP (기본 8095 — 다른 서비스와 충돌 시 변경)
PORT=8095

# RabbitMQ — 소비자 구현 시 (docs/architecture.md §6)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
