# PostgreSQL — 루트 docker-compose.yml 의 postgres-notification(기본 호스트 포트 5436) 과 정합.
# 첫 기동(빈 볼륨) 시 docker/postgres/init/04-create-notification-db.sh 가 DB·롤을 만든다.
# Compose 네트워크 안에서 Nest 컨테이너를 띄울 때: postgresql://notification_app:notification_app@postgres-notification:5432/notification_db
DATABASE_URL="postgresql://notification_app:notification_app@localhost:5436/notification_db"

# HTTP (기본 8096 — billing-service 기본 8095와 구분)
PORT=8096

# RabbitMQ — 소비자 구현 시 (docs/architecture.md §6)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
