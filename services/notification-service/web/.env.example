# Notification Next.js (`services/notification-service/web/`) — 로컬 호스트 실행 시 참고.
# 루트 `.env` / Compose 는 `docker-compose.yml` 의 `notification-web` `environment` 를 본다.

# `direct` = BFF → Nest 직접 (기본). `gateway` = BFF → API Gateway `/api/notification/**` .
NOTIFICATION_HTTP_UPSTREAM=direct

# gateway 모드일 때 필수 (트레일링 슬래시 없음)
# API_GATEWAY_URL=http://localhost:8080

# direct 모드일 때 필수 — Nest 컨트롤러가 `/api/in-app-notifications` 이므로 보통 `/api` 까지 포함
# NOTIFICATION_SERVICE_URL=http://localhost:8096/api
