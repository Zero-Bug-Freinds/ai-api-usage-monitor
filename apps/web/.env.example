# Module Federation 리모트 베이스(트레일 슬래시 없음). `apps/web/next.config.mjs`가 `/_next/static/chunks/remoteEntry.js`를 덧붙입니다.
#
# 로컬에서 team-web-mfe만 띄워 직접 붙일 때(기본 dev 포트 3012, assetPrefix `/mfe/team`):
NEXT_PUBLIC_MFE_TEAM_REMOTE_URL=http://localhost:3012/mfe/team
#
# Docker web-edge 경유 시:
# NEXT_PUBLIC_MFE_TEAM_REMOTE_URL=http://localhost:8888/mfe/team
#
# web-edge에서 /mfe/usage 노출(로컬 usage MFE 직접일 때는 해당 포트/mfe/usage 등으로 맞춤):
# NEXT_PUBLIC_MFE_USAGE_REMOTE_URL=http://localhost:8888/mfe/usage
# 팀 사이드바 anchor: 비우면 `http://localhost:8888/teams`(web-edge Main Shell). 상대 `/teams`만 쓰면 NEXT_PUBLIC_WEB_EDGE_ORIGIN(기본 8888)에 붙음.
# NEXT_PUBLIC_TEAM_SHELL_HREF=http://localhost:8888/teams
# NEXT_PUBLIC_WEB_EDGE_ORIGIN=http://localhost:8888
