# 과도기: 이 파일은 apps/web 기준. 목표 구조에서는 services/identity-service/web/.env 와
#         services/usage-service/web/.env 로 나누고, Usage 쪽에만 API_GATEWAY_URL 이 아래처럼 필요하다.
# Spring Boot identity-service 기본 포트는 8080. 게이트웨이도 8080이면 identity만 8090 등으로 올리고 아래 URL을 맞춘다(루트 .env.example 주석).
IDENTITY_SERVICE_URL=http://localhost:8090
# Identity BFF(`/api/auth/*`, `/api/identity/**`)가 Spring Identity로 프록시할 때 사용. `API_GATEWAY_URL`(보통 게이트웨이)와 혼동하지 말 것.

# Usage BFF → API Gateway 공개 베이스 URL (`/api/usage/**` → `{API_GATEWAY_URL}/api/v1/usage/**`).
# 게이트웨이의 GATEWAY_USAGE_URI·GATEWAY_PROXY_URI(아웃바운드)와 혼동 금지 — 계약: docs/contracts/gateway-proxy.md §9.
# Identity와 포트가 겹치면 게이트웨이 포트로 맞춘다.
API_GATEWAY_URL=http://localhost:8080

# 게이트웨이 `gateway.dev-mode=true`와 동일할 때: BFF가 Identity 세션으로 `X-User-Id`를 붙인다(Bearer만으로는 게이트웨이 필터가 거절).
# 운영(JWT 검증 모드)에서는 false 또는 미설정.
# GATEWAY_DEV_MODE=false
