# Hybrid runtime example (usage + identity + billing + team are run from local IDE)
# Copy to hybrid.env and adjust local ports if needed.

# Shared secret for gateway/web-edge/proxy trust boundary.
GATEWAY_SHARED_SECRET=local-dev-gateway-shared-secret-do-not-use-in-prod

# Gateway upstreams -> local JVM services
GATEWAY_USAGE_URI=http://host.docker.internal:8092
GATEWAY_IDENTITY_URI=http://host.docker.internal:8090
GATEWAY_BILLING_URI=http://host.docker.internal:8095
GATEWAY_TEAM_URI=http://host.docker.internal:8093

# Proxy service -> local identity-service (API key lookup/auth)
PROXY_KEY_SERVICE_BASE_URL=http://host.docker.internal:8090

# Web containers -> local identity-service BFF upstream
WEB_IDENTITY_SERVICE_URL=http://host.docker.internal:8090

# Web containers -> local team-service upstream (used by team-web)
WEB_TEAM_SERVICE_URL=http://host.docker.internal:8093
