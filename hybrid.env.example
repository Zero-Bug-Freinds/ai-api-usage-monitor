# Hybrid runtime (usage + identity + billing + team are run from local IDE)
# Docker containers call these local JVM services through host.docker.internal.
# Keep this file override-only. Shared defaults stay in `.env.example` / `.env`.
# Compose precedence reminder: shell env > --env-file > .env > default.

# Shared secret for gateway/web-edge/proxy trust boundary.
GATEWAY_SHARED_SECRET=local-dev-gateway-shared-secret-do-not-use-in-prod
GATEWAY_DEV_MODE=false
GATEWAY_JWT_SECRET=change-this-secret-key-to-at-least-32-bytes

# Gateway upstreams -> local JVM services
GATEWAY_USAGE_URI=http://host.docker.internal:8092
GATEWAY_IDENTITY_URI=http://host.docker.internal:8090
GATEWAY_BILLING_URI=http://host.docker.internal:8095
GATEWAY_TEAM_URI=http://host.docker.internal:8094

# Proxy service -> local identity-service (API key lookup/auth)
PROXY_KEY_SERVICE_BASE_URL=http://host.docker.internal:8090

# Web containers -> local identity-service BFF upstream
WEB_IDENTITY_SERVICE_URL=http://host.docker.internal:8090
NEXT_PUBLIC_IDENTITY_WEB_ORIGIN=http://localhost:8888
NEXT_PUBLIC_USAGE_WEB_ORIGIN=http://localhost:8888
WEB_GATEWAY_URL=http://api-gateway-service:8080

# Web containers -> local team-service upstream (used by team-web-mfe)
WEB_TEAM_SERVICE_URL=http://host.docker.internal:8094